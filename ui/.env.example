# ---------------------------------------------------------------------------
# Marathon Trainer UI — required environment variables
# ---------------------------------------------------------------------------
# Copy this file to .env.local for local development (it is gitignored).
# In CI/CD, set these as pipeline environment variables.
#
# All VITE_* variables are inlined at build time by Vite and become part of
# the compiled JS bundle — do NOT store secrets here.
# ---------------------------------------------------------------------------

# Application (client) ID of the SPA app registration in Entra External ID
VITE_ENTRA_CLIENT_ID=

# Authority URL for your Entra External ID tenant (CIAM endpoint)
# Format: https://<tenant-subdomain>.ciamlogin.com/<tenant>.onmicrosoft.com
VITE_ENTRA_AUTHORITY=

# Full scope URI for the API (from the API app registration → Expose an API)
# Format: api://<api-client-id>/<scope-name>
VITE_API_SCOPE=
