# Refuse to install any package version published within the last 7 days.
# This provides a cooldown window against supply chain attacks
# (typosquatting, account takeover, malicious publish).
# 7 days * 1440 minutes/day = 10080
#
# This rule applies to all packages — stable and prerelease alike.
# No minimum-release-age-exclude entries are permitted without explicit sign-off.
# If a package is blocked by the cooldown, wait.
minimum-release-age=10080
