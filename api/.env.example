# ---------------------------------------------------------------------------
# MarathonTraining API — required environment variables
# ---------------------------------------------------------------------------
# Copy this file to .env for local tooling that reads env files.
# In ASP.NET Core, use dotnet user-secrets (Development) or set these
# directly as environment variables (CI/CD, staging, production).
#
# Double-underscore (__) is the ASP.NET Core hierarchy separator, mapping to
# the equivalent JSON path, e.g. AzureAd__TenantId → AzureAd:TenantId.
# ---------------------------------------------------------------------------

# Microsoft Entra External ID — registered API application
AzureAd__Instance=https://login.microsoftonline.com/
AzureAd__TenantId=            # GUID of your Entra External ID tenant
AzureAd__ClientId=            # Application (client) ID of the API app registration
AzureAd__Audience=            # Usually the same as ClientId, or the api:// URI
