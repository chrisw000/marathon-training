# ---------------------------------------------------------------------------
# Marathon Trainer — root environment variables
# ---------------------------------------------------------------------------
# Used by docker-compose.yml via variable substitution (${VAR}).
#
# For local development:
#   cp .env.example .env
#   Fill in the values below — .env is gitignored.
#
# In CI/CD and production, set these as pipeline/host environment variables
# instead of using a .env file.
# ---------------------------------------------------------------------------

# ── SQL Server ───────────────────────────────────────────────────────────────
# Must meet SQL Server complexity rules:
#   at least 8 characters, mixing uppercase, lowercase, digits, and symbols.
MSSQL_SA_PASSWORD=

# ── Microsoft Entra External ID (Azure AD) ───────────────────────────────────
# These map to the AzureAd config section consumed by Microsoft.Identity.Web.
AZUREAD_INSTANCE=https://login.microsoftonline.com/
AZUREAD_TENANT_ID=        # GUID of your Entra External ID tenant
AZUREAD_CLIENT_ID=        # Application (client) ID of the API app registration
AZUREAD_AUDIENCE=         # Usually the same as AZUREAD_CLIENT_ID, or the api:// URI
